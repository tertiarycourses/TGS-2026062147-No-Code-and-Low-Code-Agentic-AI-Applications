    {
      "parameters": {
        "text": "={{ $json.body.message }}",
        "schemaType": "fromAttributes",
        "attributes": {
          "attributes": [
            {
              "name": "category",
              "type": "string",
              "description": "Route the employee's message to exactly one team. Use \"HR\" for human resources, company policy, SOP, leave, medical certificate (MC), payroll, benefits, performance / appraisal, PDPA, or any people / employee question. Use \"IT\" for technology and technical problems: password reset, account lockout, login / MFA, VPN, Wi-Fi / network, email / Outlook, laptop / hardware, software install, printer, or system errors. Output exactly \"HR\" or \"IT\".",
              "required": true
            }
          ]
        },
        "options": {
          "systemPromptTemplate": "You are a strict request router for Qualcomm's internal help desk. Read the employee's message and classify which single team should handle it.\n\nSet \"category\" to \"HR\" when the message is about human resources, company policy, SOPs, leave, medical certificates, payroll, benefits, performance / appraisal, PDPA, or anything about people and employees.\n\nSet \"category\" to \"IT\" when the message is about technology or technical problems: passwords, account access, login or MFA, VPN, Wi-Fi or network, email / Outlook, laptops or hardware, software installation, printers, or system errors.\n\nEvery message belongs to exactly one category — if it could be either, choose the closer one. Output the category as exactly \"HR\" or \"IT\" and nothing else."
        }
      },
